meta {
  name: Health Check
  type: http
  seq: 0
}

get {
  url: {{baseUrl}}/health
  body: none
  auth: none
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });
  test("should be healthy", function() {
    expect(res.body.status).to.equal("healthy");
  });
}
